# MCT BMS Backend — Environment Variables
# Copy this to .env and fill in values

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mct_bms
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# JWT
JWT_SECRET=replace_with_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_strong_secret_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated allowed origins (Electron uses file://, Tauri uses tauri://localhost)
ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost,file://

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=5
